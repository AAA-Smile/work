      <aliases enabled='yes' />
      <column caption='投币率' datatype='real' name='[Calculation_0905741428256768]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[投币数（coin）]/[播放量（play]' />
      </column>
      <column caption='互动率' datatype='real' name='[Calculation_0905741431771141]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([点赞数（like）]+2*[投币数（coin）]+1.5*[收藏数（favorite）]+[评论数（reply）])/[播放量（play]' />
      </column>
      <column caption='平均收藏率' datatype='real' name='[Calculation_0905741449003014]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([收藏数（favorite）])/sum([播放量（play])' />
      </column>
      <column caption='总播放量' datatype='integer' name='[Calculation_0905741449666567]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([播放量（play])' />
      </column>
      <column caption='播放排名' datatype='integer' name='[Calculation_2097611837607937]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(sum([播放量（play]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='点赞排名' datatype='integer' name='[Calculation_2097611839512578]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(sum([点赞数（like）]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='时长分组' datatype='string' name='[Calculation_2097611844481031]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [视频时长（秒）（durtion）] &lt; 300 THEN &apos;小于5分钟&apos;&#13;&#10;ELSEIF [视频时长（秒）（durtion）] &lt; 600 THEN &apos;5-10分钟&apos;&#13;&#10;ELSEIF [视频时长（秒）（durtion）] &lt; 1200 THEN &apos;10-20分钟&apos;&#13;&#10;ELSEIF [视频时长（秒）（durtion）] &lt; 1800 THEN &apos;20-30分钟&apos;&#13;&#10;ELSE &apos;大于30分钟&apos;&#13;&#10;END' />
      </column>
